{
  "name": "@nathanclaire/rum-capacitor",
  "version": "3.3.6",
  "description": "Capacitor integration for edge-rum — JS bridge + native iOS/Android crash capture",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "ios/",
    "android/",
    "Package.swift",
    "README.md"
  ],
  "capacitor": {
    "ios": {
      "src": "ios",
      "name": "EdgeRumCapacitor"
    },
    "android": {
      "src": "android"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@nathanclaire/rum": "workspace:*"
  },
  "peerDependencies": {
    "@capacitor/core": ">=5.0.0",
    "@capacitor/device": ">=5.0.0",
    "@capacitor/network": ">=5.0.0",
    "@capacitor/app": ">=5.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.5.4"
  }
}
