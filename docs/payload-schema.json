{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://edgemetrics.io/schemas/rum-payload/v2",
  "title": "Edge RUM Ingest Payload",
  "description": "Payload schema for edge-rum web SDK. Matches the EdgeTelemetryProcessor batch contract. The backend collector enriches each batch with tenant_id (derived from the API key) before forwarding to Kafka.",
  "type": "object",
  "required": ["type", "timestamp", "batch_size", "events"],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "const": "telemetry_batch",
      "description": "Always the string 'telemetry_batch'."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 batch flush time. Use new Date().toISOString(). Never Unix ms.",
      "examples": ["2024-01-15T10:30:00.000Z"]
    },
    "location": {
      "type": "string",
      "description": "Optional per-app/install location string (City/Country). Set via EdgeRumConfig.location.",
      "examples": ["Nairobi/Kenya"]
    },
    "batch_size": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of items in the events array. Server uses this as a sanity check.",
      "examples": [3]
    },
    "events": {
      "type": "array",
      "description": "Array of event and metric items. Server discriminates by item.type ('event' | 'metric').",
      "items": { "oneOf": [{ "$ref": "#/definitions/event" }, { "$ref": "#/definitions/metric" }] },
      "minItems": 0
    }
  },
  "definitions": {
    "event": {
      "type": "object",
      "required": ["type", "eventName", "timestamp", "attributes"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "event"
        },
        "eventName": {
          "type": "string",
          "enum": [
            "navigation",
            "screen.duration",
            "http.request",
            "performance",
            "app.crash",
            "custom_event",
            "app_lifecycle",
            "page_load",
            "network_change"
          ],
          "description": "Discriminator. Backend routes by this value. Metric items use the separate 'metric' shape (no eventName)."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "examples": ["2024-01-15T10:30:00.123Z"]
        },
        "attributes": {
          "$ref": "#/definitions/attributes"
        }
      }
    },
    "metric": {
      "type": "object",
      "required": ["type", "metricName", "value", "timestamp", "attributes"],
      "additionalProperties": false,
      "description": "Metric item. metricName and value live at the item root, NOT inside attributes. Produced by EdgeRum.time().end().",
      "properties": {
        "type": {
          "type": "string",
          "const": "metric"
        },
        "metricName": {
          "type": "string",
          "examples": ["image_upload"]
        },
        "value": {
          "type": "number",
          "examples": [890]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "attributes": {
          "$ref": "#/definitions/attributes"
        }
      }
    },
    "attributes": {
      "type": "object",
      "description": "Flat key-value object. All values must be primitives — no nested objects, no arrays. Context (app, device, session, user) merged here alongside event-specific fields.",
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      },
      "properties": {
        "app.name": { "type": "string", "examples": ["MyApp"] },
        "app.version": { "type": "string", "examples": ["2.1.0"] },
        "app.package_name": {
          "type": "string",
          "description": "App package / bundle ID. Required by the collector for identity resolution.",
          "examples": ["com.yourco.app"]
        },
        "app.build_number": { "type": "string", "examples": ["42", ""] },
        "app.environment": {
          "type": "string",
          "enum": ["production", "staging", "development"]
        },
        "device.id": {
          "type": "string",
          "description": "Persistent device identifier. Required by the collector. Format: device_{timestampMs}_{8hexchars}_{platform}.",
          "pattern": "^device_\\d+_[a-f0-9]{8}_(ios|android|web)$",
          "examples": ["device_1704067200000_a8b9c2d1_ios"]
        },
        "device.platform": {
          "type": "string",
          "enum": ["ios", "android", "web"]
        },
        "device.model": { "type": "string", "examples": ["iPhone 15 Pro"] },
        "device.manufacturer": { "type": "string", "examples": ["Apple"] },
        "device.os": { "type": "string", "examples": ["ios"] },
        "device.platform_version": { "type": "string", "examples": ["17.4"] },
        "device.isVirtual": { "type": "boolean" },
        "device.screenWidth": { "type": "number" },
        "device.screenHeight": { "type": "number" },
        "device.pixelRatio": { "type": "number" },
        "device.batteryLevel": { "type": "number", "minimum": 0, "maximum": 1 },
        "device.batteryCharging": { "type": "boolean" },
        "network.type": {
          "type": "string",
          "enum": ["wifi", "cellular", "none", "unknown"],
          "description": "Connection class. Preserved across the firewall — distinct from http.* attributes on http.request events."
        },
        "network.effectiveType": {
          "type": "string",
          "enum": ["4g", "3g", "2g", "slow-2g", "unknown"]
        },
        "network.downlinkMbps": { "type": "number" },
        "session.id": {
          "type": "string",
          "description": "Required by the collector. Format: session_{timestampMs}_{8hexchars}_{platform}.",
          "pattern": "^session_\\d+_[a-f0-9]{8}_(ios|android|web)$"
        },
        "session.start_time": {
          "type": "string",
          "format": "date-time"
        },
        "session.sequence": {
          "type": "number",
          "minimum": 0,
          "description": "Monotonic counter. Increments on each successfully sent payload."
        },
        "user.id": {
          "type": "string",
          "description": "Required by the collector. SDK-owned anonymous ID until EdgeRum.identify() attaches details.",
          "examples": ["user_1704067200000_abcd1234"]
        },
        "user.name": { "type": "string" },
        "user.email": { "type": "string" },
        "user.phone": { "type": "string" },
        "sdk.version": { "type": "string", "examples": ["3.0.0"] },
        "sdk.platform": { "type": "string", "const": "ionic-angular-capacitor" }
      }
    },
    "navigationAttributes": {
      "description": "Extra attributes for eventName: navigation. Marks the entry hop in a user journey.",
      "properties": {
        "navigation.from_screen": { "type": "string", "examples": ["/tabs/products"] },
        "navigation.to_screen": { "type": "string", "examples": ["/tabs/profile"] },
        "navigation.method": {
          "type": "string",
          "enum": ["push", "pop", "replace", "initial", "cancel"]
        },
        "navigation.route_type": {
          "type": "string",
          "enum": ["main_flow", "deeplink", "modal", "settings"]
        },
        "navigation.has_arguments": { "type": "boolean" },
        "navigation.timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "screenDurationAttributes": {
      "description": "Extra attributes for eventName: screen.duration. Emitted on screen exit with the full dwell time.",
      "properties": {
        "screen.name": { "type": "string", "examples": ["/tabs/profile"] },
        "screen.duration_ms": {
          "type": "number",
          "description": "Now() - enteredAt at the moment of exit."
        },
        "screen.exit_method": {
          "type": "string",
          "description": "Free string. Currently always 'navigate'; future values may include 'back', 'background', 'close'."
        },
        "screen.timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "httpRequestAttributes": {
      "description": "Extra attributes for eventName: http.request.",
      "properties": {
        "http.url": {
          "type": "string",
          "description": "Full URL with PII query params stripped."
        },
        "http.method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
        },
        "http.status_code": {
          "type": "number",
          "minimum": 0,
          "description": "0 when the request never reached a response (DNS, abort, timeout)."
        },
        "http.duration_ms": { "type": "number" },
        "http.success": {
          "type": "boolean",
          "description": "True when 200 <= status < 400 and the request was not aborted."
        },
        "http.timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "performanceAttributes": {
      "description": "Extra attributes for eventName: performance (Web Vitals)",
      "properties": {
        "performance.metric_name": {
          "type": "string",
          "enum": ["LCP", "INP", "CLS", "FCP", "TTFB"]
        },
        "performance.value": { "type": "number" },
        "performance.unit": { "type": "string", "enum": ["ms", "score"] },
        "performance.rating": { "type": "string", "enum": ["good", "needs-improvement", "poor"] },
        "performance.screen": { "type": "string" }
      }
    },
    "crashAttributes": {
      "description": "Extra attributes for eventName: app.crash",
      "properties": {
        "exception_type": { "type": "string", "examples": ["TypeError"] },
        "message": { "type": "string" },
        "stacktrace": { "type": "string" },
        "is_fatal": { "type": "boolean" },
        "handled": { "type": "boolean" },
        "error_context": { "type": "string", "examples": ["screen:/tabs/profile"] },
        "cause": { "type": "string" },
        "runtime": { "type": "string", "enum": ["webview", "native"] }
      }
    },
    "customEventAttributes": {
      "description": "Extra attributes for eventName: custom_event",
      "properties": {
        "event.name": { "type": "string" }
      },
      "additionalProperties": { "type": ["string", "number", "boolean"] }
    },
    "metricAttributes": {
      "description": "Extra attributes for type: metric items.",
      "properties": {
        "metric.unit": { "type": "string", "const": "ms" }
      },
      "additionalProperties": { "type": ["string", "number", "boolean"] }
    },
    "appLifecycleAttributes": {
      "description": "Extra attributes for eventName: app_lifecycle",
      "properties": {
        "lifecycle.event": { "type": "string", "enum": ["foreground", "background"] },
        "lifecycle.cold_start_ms": { "type": "number" }
      }
    },
    "pageLoadAttributes": {
      "description": "Extra attributes for eventName: page_load — WEB ONLY.",
      "properties": {
        "page.ttfb_ms": { "type": "number" },
        "page.dom_content_loaded_ms": { "type": "number" },
        "page.load_duration_ms": { "type": "number" },
        "page.resource_count": { "type": "number" },
        "page.route": { "type": "string" }
      }
    },
    "networkChangeAttributes": {
      "description": "Extra attributes for eventName: network_change — WEB ONLY.",
      "properties": {
        "network.connected": { "type": "boolean" },
        "network.type": { "type": "string", "enum": ["wifi", "cellular", "none", "unknown"] },
        "network.previous_type": { "type": "string", "enum": ["wifi", "cellular", "none", "unknown"] }
      }
    }
  }
}
